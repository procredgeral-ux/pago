# ============================================
# Database Configuration (Prisma)
# ============================================
# Railway PostgreSQL - Defina no Railway Dashboard:
# Settings → Variables → Add DATABASE_URL
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bigdatacorp
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/bigdatacorp

# ============================================
# Application Settings
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# Optional Services
# ============================================

# Upstash Redis (for rate limiting)
# UPSTASH_REDIS_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_TOKEN=your-redis-token

# Resend (for email notifications)
# RESEND_API_KEY=re_xxxxxxxx

