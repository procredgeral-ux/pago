# ============================================
# Mercado Pago - AMBIENTE CONFIGURAÇÃO
# ============================================
# Opções: 'development' (teste/sandbox) ou 'production' (pagamentos reais)
# development = Teste com sandbox Mercado Pago (não cobra de verdade)
# production = Pagamentos reais com dinheiro real
