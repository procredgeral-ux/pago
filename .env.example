# ============================================
# BigDataCorp API Platform - Environment Variables
# ============================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database (PostgreSQL)
# Railway provides this automatically, or use your own
DATABASE_URL=postgresql://user:password@host:5432/database
DIRECT_URL=postgresql://user:password@host:5432/database

# ============================================
# Mercado Pago - TEST Environment (Development)
# ============================================
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxxxxxx
MP_PIX_KEY=your-pix-key@email.com

# Mercado Pago - PRODUCTION Environment (When ready)
# MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx
# MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx

# Mercado Pago Plans (Create in Mercado Pago dashboard)
MP_BASIC_PLAN_ID=plan_basic_id_here
MP_PRO_PLAN_ID=plan_pro_id_here
MP_ENTERPRISE_PLAN_ID=plan_enterprise_id_here

# ============================================
# Application Settings
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# Optional Services
# ============================================

# Upstash Redis (for rate limiting)
# UPSTASH_REDIS_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_TOKEN=your-redis-token

# Resend (for email notifications)
# RESEND_API_KEY=re_xxxxxxxx

# ============================================
# Notes:
# - Copy this file to .env.local for local development
# - NEVER commit .env or .env.local to git
# - Railway will use its own environment variables
# ============================================
